 CellChangeTimes->{{3.974406461307975*^9, 3.9744064778441477`*^9}, 
   3.9744066322823544`*^9},
 CellLabel->"Out[48]=",ExpressionUUID->"812785cf-3ade-4db0-9e34-36f5b0b13ff6"],

Cell[BoxData[
