   FractionBox[
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Na0", "-", "ra"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"rA", "-", "ra"}], ")"}]}], 
    RowBox[{
     RowBox[{"-", "ra"}], " ", 
     RowBox[{"(", 
      RowBox[{"Na0", "+", "rA", "-", "ra"}], ")"}]}]], "]"}]}]], "Input",
 CellChangeTimes->{{3.9744058429973927`*^9, 3.974405906105282*^9}, {
  3.974406040772855*^9, 
