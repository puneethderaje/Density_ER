 CellLabel->"Out[46]=",ExpressionUUID->"7d1dbdd5-abed-4801-9a54-47f0a78903c8"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", "rA", " ", "u", " ", 
   RowBox[{"Log", "[", 
    RowBox[{"1", "-", 
     FractionBox["Na0", "ra"]}], "]"}]}], 
  RowBox[{"1", "+", "rA"}]]], "Output",
