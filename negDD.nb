Cell["\<\
To get the establishment probability of a mutant arising at time t we use the \
expression from Uecker et al 2011 (eqn 16a). This depends on both the mutant \
growth rate (birth - death) and the sum of mutant birth and death rates. The \
mutant growth rate is rA - NA - \[Alpha] Na, and we can assume NA=0. If we \
split this growth between birth and death in some way that the Na term \
cancels out, eg, bA = 1/2 + rA/2 - \[Alpha] Na/2 and dA =1/2 - rA/2 + \
\[Alpha] Na/2 (see also Uecker et al 2014 eqn A2), then we can do the double \
integral:\
\>", "Text",
 CellChangeTimes->{{3.974388909785873*^9, 3.974388931247658*^9}, {
  3.974389141054566*^9, 3.974389245828188*^9}, {3.974401586249405*^9, 
  3.974401712575965*^9}, {3.9744018693890667`*^9, 3.974401903518897*^9}, {
  3.974401939704108*^9, 3.974402000691297*^9}, {3.9744021377206383`*^9, 
  3.974402237108803*^9}, {3.974402964344904*^9, 
  3.9744029768729477`*^9}},ExpressionUUID->"0999dd1f-29d0-474e-89d4-\
3fa574714e60"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"i1", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{"dNAdt", ",", "NA"}], "]"}], "/.", 
        RowBox[{"NA", "->", "0"}]}], "/.", 
       RowBox[{"Na", "->", "Nat"}]}], "/.", 
      RowBox[{"t", "\[Rule]", "\[Tau]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Tau]", ",", "T", ",", "t"}], "}"}]}], "]"}]}], 
  "*)"}]], "Input",
 CellChangeTimes->{{3.968870962003665*^9, 3.968870965315699*^9}, {
   3.9743880241735888`*^9, 3.974388027805545*^9}, 3.9743886584332333`*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"e6a3c76b-a1fc-455f-b94d-b5f6eae339a1"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"i2", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{"-", "i1"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "T", ",", "\[Infinity]"}], "}"}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rA", ">", "0"}], ",", 
        RowBox[{"\[Alpha]", ">", "0"}], ",", 
        RowBox[{"ra", "<", "0"}], ",", 
        RowBox[{"Na0", ">", "0"}], ",", 
        RowBox[{"T", ">", "0"}]}], "}"}]}]}], "]"}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.9688709822646837`*^9, 3.9688709825282917`*^9}, 
   3.970043633961142*^9, {3.974388061422418*^9, 3.974388068312909*^9}, 
   3.9743882094083843`*^9, {3.9743892668190536`*^9, 3.974389292100739*^9}, {
   3.974401927423697*^9, 3.974401969893565*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"ace6e9d4-af67-496f-bd10-13d1d1effee6"],

Cell["just copying the answer here  to be faster", "Text",
 CellChangeTimes->{{3.9700436415165777`*^9, 
  3.970043655947061*^9}},ExpressionUUID->"bf4c3689-2a6c-4356-a231-\
edc295344973"],

Cell[BoxData[
 RowBox[{
  RowBox[{"i2", "=", 
   FractionBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "Na0"}], "+", "ra"}], ")"}], "\[Alpha]"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"ra", " ", "T"}]]}], ")"}], " ", "Na0"}], "+", "ra"}], 
       ")"}], 
      RowBox[{"-", "\[Alpha]"}]], " ", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["rA", "ra"]}], ",", 
       RowBox[{"-", "\[Alpha]"}], ",", 
       RowBox[{"1", "-", 
        FractionBox["rA", "ra"]}], ",", 
       FractionBox[
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"ra", " ", "T"}]], " ", "Na0"}], 
        RowBox[{"Na0", "-", "ra"}]]}], "]"}]}], "rA"]}], ";"}]], "Input",
 CellChangeTimes->{{3.970043627559125*^9, 3.9700436288359756`*^9}, {
  3.974388204469605*^9, 3.974388217176985*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"43f532c4-76b7-45d4-9383-d4a53fc8e9c1"],

Cell["the establishment probability is then", "Text",
 CellChangeTimes->{{3.974388611894574*^9, 
  3.974388617752202*^9}},ExpressionUUID->"df618f02-380c-4e31-98ff-\
8f08c02075f1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pest", " ", "=", 
  RowBox[{"2", "/", 
   RowBox[{"(", 
    RowBox[{"1", "+", "i2"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.974388646069694*^9, 3.974388647104988*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"645eff21-9ec6-41bc-96a7-c3a9851308b0"],

Cell[BoxData[
 FractionBox["2", 
  RowBox[{"1", "+", 
   FractionBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "Na0"}], "+", "ra"}], ")"}], "\[Alpha]"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"ra", " ", "T"}]]}], ")"}], " ", "Na0"}], "+", "ra"}], 
       ")"}], 
      RowBox[{"-", "\[Alpha]"}]], " ", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["rA", "ra"]}], ",", 
       RowBox[{"-", "\[Alpha]"}], ",", 
       RowBox[{"1", "-", 
        FractionBox["rA", "ra"]}], ",", 
       FractionBox[
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"ra", " ", "T"}]], " ", "Na0"}], 
        RowBox[{"Na0", "-", "ra"}]]}], "]"}]}], "rA"]}]]], "Output",
 CellChangeTimes->{{3.974388644196273*^9, 3.9743886483994226`*^9}, 
   3.974402253216728*^9, 3.974405538163788*^9},
 CellLabel->"Out[12]=",ExpressionUUID->"479a30ef-1f03-4cf2-8ded-cc373778c3ba"]
}, Open  ]],

Cell["check that this reduces to Uecker et al 2011 eqn 17", "Text",
