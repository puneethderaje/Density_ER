Notebook[{

Cell[CellGroupData[{
Cell["ER by DNM with negative DD", "Title",
 CellChangeTimes->{{3.974387211144099*^9, 3.974387224314023*^9}, {
  3.974387261251354*^9, 
  3.974387267004231*^9}},ExpressionUUID->"d8fe5d99-3fc3-4bcd-8f02-\
9b57d3998fdd"],

Cell[CellGroupData[{

Cell["model", "Section",
 CellChangeTimes->{{3.9743875764382343`*^9, 
  3.97438759652917*^9}},ExpressionUUID->"2589229d-f080-4c43-810b-\
b28bef8ebdc5"],

Cell["lotka-volterra competition", "Text",
 CellChangeTimes->{{3.974387635656908*^9, 3.9743876429732428`*^9}, {
  3.974387720448023*^9, 3.974387725855792*^9}, {3.974388507647339*^9, 
  3.974388508211358*^9}},ExpressionUUID->"de7b9f0b-f05e-43bf-80ba-\
f8e746395770"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dNadt", "=", 
    RowBox[{"Na", 
     RowBox[{"(", 
      RowBox[{"ra", "-", "Na", "-", 
       RowBox[{"\[Beta]", " ", "NA"}]}], ")"}]}]}], ";"}], " ", 
  RowBox[{"(*", "wildtype", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dNAdt", "=", 
    RowBox[{"NA", 
     RowBox[{"(", 
      RowBox[{"rA", "-", "NA", "-", 
       RowBox[{"\[Alpha]", " ", "Na"}]}], ")"}]}]}], ";"}], " ", 
  RowBox[{"(*", "mutant", "*)"}]}]}], "Input",
 CellChangeTimes->{{3.974387648050761*^9, 3.974387716128611*^9}, {
  3.974387839730076*^9, 3.9743878423399153`*^9}, {3.9743885114333277`*^9, 
  3.9743885144359827`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"de6062f8-593d-41d8-abe9-c987a56ae301"],

Cell["like eqn A.3 in Czuppon et al 2023", "Text",
 CellChangeTimes->{{3.9743885178848267`*^9, 
  3.9743885347637033`*^9}},ExpressionUUID->"3864a01b-0dfd-4c05-a3ea-\
ee957ecc8c24"],

Cell["\<\
for simplicity ignore sgv and just think about rescue from dnm, starting with \
Na=1, NA=0\
\>", "Text",
 CellChangeTimes->{{3.974388247012744*^9, 
  3.974388286243898*^9}},ExpressionUUID->"0551c5c1-debb-4b61-be55-\
115d6cf93413"],

Cell[TextData[{
 "then the prob of rescue is 1 - Exp[-\[Integral] Na(t) u ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "est"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ad8c85db-053f-42cf-8d78-1b3d5ff046f4"],
 "(t) dt]. We next get Na and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "est"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5fbb5aea-e21f-488c-a21b-325d65244f43"],
 " then try to integrate."
}], "Text",
 CellChangeTimes->{{3.974388299037166*^9, 3.974388386622468*^9}, {
  3.974388540334855*^9, 
  3.9743885408048973`*^9}},ExpressionUUID->"c95f2bdf-5f94-42df-b66c-\
c3eeb43ab5da"]
}, Open  ]],

Cell[CellGroupData[{

Cell["wildtype decline", "Section",
 CellChangeTimes->{{3.974387607024473*^9, 
  3.974387612144579*^9}},ExpressionUUID->"4587d936-d681-42a8-84b0-\
b58b7b3f5977"],

Cell["wildtype decline", "Text",
 CellChangeTimes->{{3.9743882913233147`*^9, 
  3.974388296230172*^9}},ExpressionUUID->"28d367c7-d6d8-49a3-8a6c-\
b86d82402030"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"DSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"Na", "[", "t", "]"}], ",", "t"}], "]"}], "==", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"dNadt", "/.", 
          RowBox[{"NA", "->", "0"}]}], "/.", 
         RowBox[{"Na", "->", 
          RowBox[{"Na", "[", "t", "]"}]}]}], ")"}]}], ",", " ", 
      RowBox[{
       RowBox[{"Na", "[", "0", "]"}], "==", "Na0"}]}], "}"}], ",", 
    RowBox[{"Na", "[", "t", "]"}], ",", "t"}], "]"}], ";"}], "\n", 
 RowBox[{"Nat", " ", "=", " ", 
  RowBox[{
   RowBox[{"Na", "[", "t", "]"}], "/.", 
   RowBox[{"Flatten", "[", "%", "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.97438776777234*^9, 3.974387808816387*^9}, 
   3.974388550428575*^9},
 CellLabel->"In[3]:=",ExpressionUUID->"9e76fd8d-df56-4540-a4b7-53107b6afeb1"],

Cell[BoxData[
 TemplateBox[{
  "DSolve", "ifun", 
   "\"Inverse functions are being used by DSolve, so some solutions may not \
be found.\"", 2, 3, 1, 30185575179285550859, "Local"},
  "MessageTemplate",
  BaseStyle->"MSG"]], "Message",
 CellChangeTimes->{
  3.968857846417523*^9, 3.9688728070602627`*^9, 3.9689258442507963`*^9, 
   3.969999467280842*^9, 3.970043617436762*^9, 3.970043694614731*^9, 
   3.9700550153792953`*^9, 3.9700651451526423`*^9, 3.974387310485277*^9, {
   3.9743877847173767`*^9, 3.974387809341538*^9}, 3.9743878660442457`*^9, 
   3.9743885514564953`*^9, 3.974405536889374*^9},
 CellLabel->
  "During evaluation of \
In[3]:=",ExpressionUUID->"6cb2374c-858a-4c3f-b192-02e703a2fc38"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"ra", " ", "t"}]], " ", "Na0", " ", "ra"}], 
  RowBox[{
   RowBox[{"-", "Na0"}], "+", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"ra", " ", "t"}]], " ", "Na0"}], "+", "ra"}]]], "Output",
 CellChangeTimes->{
  3.968857846461231*^9, 3.968872807065216*^9, 3.968925844256124*^9, 
   3.969999467285572*^9, 3.970043617442029*^9, 3.970043694619007*^9, 
   3.9700550154204884`*^9, 3.970065145157319*^9, 3.974387310508368*^9, {
   3.974387784770254*^9, 3.974387809347158*^9}, 3.974387866048912*^9, 
   3.9743885514617643`*^9, 3.9744055369365187`*^9},
 CellLabel->"Out[4]=",ExpressionUUID->"ef2dc7dd-baa4-4059-8869-08a725161d8c"]
}, Open  ]],

Cell["\<\
this is eqn A.2 in Czuppon et al 2023 with xs=Na, \[Gamma]=1, \
\[Beta]-\[Delta]-\[Alpha]=ra \
\>", "Text",
 CellChangeTimes->{{3.974387314627836*^9, 
  3.974387384142057*^9}},ExpressionUUID->"973c1309-b58b-404f-8e73-\
8510dc20f37a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Nat", "-", 
   FractionBox[
    RowBox[{" ", "Na0"}], 
    RowBox[{" ", 
     RowBox[{
      RowBox[{"Na0", "/", "ra"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Na0", "/", "ra"}]}], ")"}], " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "ra"}], " ", "t"}]]}]}]}]]}], "//", 
  "Simplify"}]], "Input",
 CellChangeTimes->{{3.974387422887472*^9, 3.974387507657279*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"7db7a623-a760-470c-a13d-e993d8f51d53"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.974387423619205*^9, 3.974387507977845*^9, 
  3.974388554420504*^9, 3.9744055371786137`*^9},
 CellLabel->"Out[5]=",ExpressionUUID->"758c3b54-1486-41ac-801b-efffbf0ad714"]
}, Open  ]],

Cell["\<\
note we decline quicker at first due to competition (density-dependence)\
\>", "Text",ExpressionUUID->"cc64bc2c-4d89-4e20-b3eb-2d1b960790e5"],

