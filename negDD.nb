29eb8642327b"],

Cell[BoxData[
 RowBox[{"2", " ", 
  RowBox[{"(", 
   RowBox[{"rA", "-", "ra"}], ")"}], " ", "u", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"Log", "[", 
     FractionBox[
      RowBox[{" ", 
       RowBox[{"rA", "-", "ra"}]}], 
      RowBox[{"-", "ra"}]], "]"}], "+", 
    RowBox[{"Log", "[", 
     FractionBox[
      RowBox[{"Na0", "-", "ra"}], 
