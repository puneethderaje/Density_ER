 CellLabel->"Out[47]=",ExpressionUUID->"52b295db-42b0-46a4-beb7-aaa7559fb971"]
}, Open  ]],

Cell["\<\
which is still in contrast to the classic case of an exponentially declining \
wildtype, where rescue depends on Na0\
\>", "Text",
 CellChangeTimes->{{3.974406374370545*^9, 3.974406405292054*^9}, {
  3.974406482080793*^9, 
