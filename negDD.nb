Cell["\<\
warning: this is not what Czuppon et al 2023 get. They seem to replace mutant \
growth rate with mutant selective advantage (incorrect), which is a constant \
when \[Alpha]=\[Beta] (allowing them to get a solution in a special case).   \
See their discussion between eqns B.7 and B.8, and their Mathematica \
notebook: \
https://github.com/pczuppon/AMRWithinHost/blob/main/SI/Mathematica/withinHost_\
densityBirth.nb. I haven\[CloseCurlyQuote]t talked with Pete about this yet.\
\>", "Text",
 CellChangeTimes->{{3.974388668212245*^9, 3.974388685174959*^9}, {
  3.974403795266458*^9, 
  3.9744039529993258`*^9}},ExpressionUUID->"4b054ebd-fe4e-42b8-8689-\
6cd0e72652e6"],

Cell["\<\
Uecker et al 2011 discuss a rescue scenario in their appendix, but \
numerically solve for pest and prescue\
\>", "Text",
 CellChangeTimes->{{3.974404454479272*^9, 
  3.974404511694439*^9}},ExpressionUUID->"58e3ad85-fca5-42b3-a824-\
7934313be8d5"],

Cell["\<\
Uecker et al 2014 only give numerical results for prescue with competition\
\>", "Text",
 CellChangeTimes->{{3.9744045190938683`*^9, 
  3.9744045806877537`*^9}},ExpressionUUID->"7d4a9866-1da0-48cf-861a-\
3d3d6411f8f6"],

Cell["\<\
but can one figure out the dependence of prescue on N0 in all these scenarios \
without worrying about solving the integrals?\
\>", "Text",
 CellChangeTimes->{{3.974404686583403*^9, 
  3.974404721580058*^9}},ExpressionUUID->"4449e758-303b-4d11-8b0a-\
d7297bf25805"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["probability of rescue", "Section",
 CellChangeTimes->{{3.974388603200541*^9, 
  3.9743886074648857`*^9}},ExpressionUUID->"96675a9d-a09e-48dd-aa24-\
d84c86213528"],

Cell["\<\
to get the probability of rescue from dnm we need to integrate the following \
over time\
\>", "Text",
 CellChangeTimes->{{3.974404763902459*^9, 
  3.974404799463187*^9}},ExpressionUUID->"4a2adbc4-3e93-4837-b6bf-\
c6a803e9e0c0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rdnm", "=", 
  RowBox[{"Nat", " ", 
   RowBox[{"(", 
    RowBox[{"pest", "/.", 
     RowBox[{"T", "->", "t"}]}], ")"}], " ", "u"}]}]], "Input",
 CellChangeTimes->{{3.97440478850597*^9, 3.9744048019375067`*^9}, {
  3.97440483268476*^9, 3.97440483669173*^9}, {3.9744055720574713`*^9, 
  3.9744055729656*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"4d62b8e6-e93f-4678-bdfb-7d477c3861d9"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"ra", " ", "t"}]], " ", "Na0", " ", "ra", " ", "u"}], 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "Na0"}], "+", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"ra", " ", "t"}]], " ", "Na0"}], "+", "ra"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     FractionBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "Na0"}], "+", "ra"}], ")"}], "\[Alpha]"], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{"ra", " ", "t"}]]}], ")"}], " ", "Na0"}], "+", "ra"}], 
         ")"}], 
        RowBox[{"-", "\[Alpha]"}]], " ", 
       RowBox[{"Hypergeometric2F1", "[", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["rA", "ra"]}], ",", 
         RowBox[{"-", "\[Alpha]"}], ",", 
         RowBox[{"1", "-", 
          FractionBox["rA", "ra"]}], ",", 
         FractionBox[
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"ra", " ", "t"}]], " ", "Na0"}], 
          RowBox[{"Na0", "-", "ra"}]]}], "]"}]}], "rA"]}], ")"}]}]]], "Output",\

 CellChangeTimes->{{3.974404791423493*^9, 3.97440480240617*^9}, 
   3.974404837129717*^9, 3.974405543009275*^9, 3.974405573734358*^9},
 CellLabel->"Out[15]=",ExpressionUUID->"9eac4a34-49d6-4016-b171-4add4b2250c8"]
}, Open  ]],

Cell["not possible in general but just consider \[Alpha]=1", "Text",
 CellChangeTimes->{{3.974405557691515*^9, 
  3.974405566844903*^9}},ExpressionUUID->"58ce6fc7-c6aa-402b-a844-\
20016b04392b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rdnm1", "=", 
  RowBox[{
   RowBox[{"rdnm", "/.", 
    RowBox[{"\[Alpha]", "->", "1"}]}], "//", "Simplify"}]}]], "Input",
 CellChangeTimes->{{3.974405576837796*^9, 3.974405609000765*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"f1b85312-d140-42ff-98bf-c144bc828362"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"ra", " ", "t"}]], " ", "Na0", " ", "ra", " ", 
   RowBox[{"(", 
    RowBox[{"ra", "-", "rA"}], ")"}], " ", "rA", " ", "u"}], 
  RowBox[{
   RowBox[{"ra", " ", 
    RowBox[{"(", 
     RowBox[{"ra", "-", "rA"}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", "rA"}], ")"}]}], "-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"ra", " ", "t"}]]}], ")"}], " ", "Na0", " ", "rA", " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", "rA"}], ")"}]}], "+", 
   RowBox[{"Na0", " ", "ra", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"ra", " ", "t"}]]}], ")"}], " ", "rA"}]}], 
     ")"}]}]}]]], "Output",
 CellChangeTimes->{{3.974405586819248*^9, 3.974405593198738*^9}},
 CellLabel->"Out[17]=",ExpressionUUID->"609df47e-5d1e-43ce-a435-dc7f14cfbdba"]
}, Open  ]],

Cell["\<\
and simplify with r small (and therefore also N0 small, and t large)\
\>", "Text",
 CellChangeTimes->{{3.97440559600325*^9, 
  3.974405618428295*^9}},ExpressionUUID->"1e786075-4049-4a10-943b-\
a38422ed6b91"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rdnm1app", "=", 
  RowBox[{
   RowBox[{"Normal", "[", 
    RowBox[{"Series", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"rdnm1", "/.", 
          RowBox[{"ra", "->", 
           RowBox[{"ra", " ", "\[Epsilon]"}]}]}], "/.", 
         RowBox[{"rA", "->", 
          RowBox[{"rA", " ", "\[Epsilon]"}]}]}], "/.", 
        RowBox[{"Na0", "->", 
         RowBox[{"Na0", " ", "\[Epsilon]"}]}]}], "/.", 
       RowBox[{"t", "->", 
        RowBox[{"t", "/", "\[Epsilon]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Epsilon]", ",", "0", ",", "1"}], "}"}]}], "]"}], "]"}], "/.", 
   RowBox[{"\[Epsilon]", "->", "1"}]}]}]], "Input",
 CellChangeTimes->{{3.974405620399477*^9, 3.974405648064539*^9}, {
  3.974405692064616*^9, 3.974405694280224*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"7b7d2760-8b0e-4261-89be-c7ede2654cdb"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"ra", " ", "t"}]], " ", "Na0", " ", "ra", " ", 
   RowBox[{"(", 
    RowBox[{"ra", "-", "rA"}], ")"}], " ", "rA", " ", "u"}], 
  RowBox[{
   RowBox[{"ra", " ", 
    RowBox[{"(", 
     RowBox[{"ra", "-", "rA"}], ")"}]}], "-", 
   RowBox[{"Na0", " ", 
    RowBox[{"(", 
     RowBox[{"ra", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"ra", " ", "t"}]]}], ")"}], " ", "rA"}]}], 
     ")"}]}]}]]], "Output",
 CellChangeTimes->{3.9744056502292767`*^9, 3.974405695067481*^9},
 CellLabel->"Out[19]=",ExpressionUUID->"8e18ee5c-c366-4284-8739-0e9e57f7bb77"]
}, Open  ]],

Cell["giving", "Text",
 CellChangeTimes->{{3.974405761871304*^9, 
  3.974405762463373*^9}},ExpressionUUID->"2c075d1f-506c-4a6e-bd1f-\
ee425eba154a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pdnm1", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{"rdnm1app", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"{", 
      RowBox[{"ra", "<", "0"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.97440567085424*^9, 3.974405716113556*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"2fd7dcf5-959d-44e3-945d-52946a237638"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "2"}], " ", 
  RowBox[{"(", 
   RowBox[{"ra", "-", "rA"}], ")"}], " ", "u", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"Log", "[", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Na0", "-", "ra"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"ra", "-", "rA"}], ")"}]}], ")"}]}], "]"}], "-", 
    RowBox[{"Log", "[", 
     RowBox[{"ra", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "Na0"}], "+", "ra", "-", "rA"}], ")"}]}], "]"}]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{3.974405718093663*^9, 3.9744057724075212`*^9},
 CellLabel->"Out[21]=",ExpressionUUID->"2e6b6e02-f6be-4dea-9885-508033cf5609"]
}, Open  ]],

Cell["which can be rearranged into", "Text",
 CellChangeTimes->{{3.974405877854164*^9, 
  3.974405882358066*^9}},ExpressionUUID->"da28217c-6234-4c4f-9538-\
61d4ff2f5756"],

Cell[BoxData[
 RowBox[{"2", " ", 
  RowBox[{"(", 
